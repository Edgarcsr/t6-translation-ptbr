{
  "$schema": "https://schema.tauri.app/config/2",
  "version": "0.8.0",
  "productName": "T6 Translation PT-BR",
  "identifier": "com.edgar.t6-translation-ptbr",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "T6 Translation PT-BR",
        "width": 800,
        "height": 600,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/app-icon.svg",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
